{
  "manifest_version": 3,
  "name": "crew-flags",
  "description": "Minimal extension active on Crew stage/prod domains.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://crew.preply.com/*",
    "https://*.preply.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://crew.preply.com/*",
        "https://*.preply.org/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "crew-flags",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
